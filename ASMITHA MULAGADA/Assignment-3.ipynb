   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "cbcecf7f",
   "metadata": {},
   "outputs": [],
   "source": [
    "data = pd.read_csv(\"salary_data.csv\")\n",
    "\n",
    "X = data['YearsExperience'].values\n",
    "y = data['Salary'].values\n",
    "\n",
    "n = len(X)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "025f620d",
   "metadata": {},
   "outputs": [],
   "source": [
    "m = 0\n",
    "b = 0\n",
    "\n",
    "learning_rate = 0.0001\n",
    "iterations = 10000\n",
    "\n",
    "n = len(X)\n",
    "\n",
    "cost_history = []"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "8117b6b8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Slope (m): 11769.706882688291\n",
      "Intercept (b): 10160.057298278904\n"
     ]
    }
   ],
   "source": [
    "for i in range(iterations):\n",
    "\n",
    "    y_pred = m * X + b\n",
    "\n",
    "    cost = (1/n) * np.sum((y - y_pred) ** 2)\n",
    "    cost_history.append(cost)\n",
    "\n",
    "    dm = (-2/n) * np.sum(X * (y - y_pred))\n",
    "    db = (-2/n) * np.sum(y - y_pred)\n",
    "\n",
    "    m = m - learning_rate * dm\n",
    "    b = b - learning_rate * db\n",
    "\n",
    "print(\"Slope (m):\", m)\n",
    "print(\"Intercept (b):\", b)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "a51d2dbe",
   "metadata": {},
   "outputs": [],
   "source": [
    "x_mean = np.mean(X)\n",
    "y_mean = np.mean(y)\n",
    "\n",
    "numerator = 0\n",
    "denominator = 0\n",
    "\n",
    "for i in range(len(X)):\n",
    "    numerator += (X[i] - x_mean) * (y[i] - y_mean)\n",
    "    denominator += (X[i] - x_mean) ** 2\n",
    "\n",
    "theta1 = numerator / denominator\n",
    "\n",
    "theta0 = y_mean - theta1 * x_mean"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "063b8faf",
   "metadata": {},
   "outputs": [],
   "source": [
    "y_pred = theta1 * X + theta0"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "61ca4a96",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 600x400 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.figure(figsize=(6,4))\n",
    "\n",
    "plt.scatter(X, y, color='purple', label='Actual Data')\n",
    "\n",
    "plt.plot(X, y_pred, color='orange', linewidth=2, label='Regression Line')\n",
    "\n",
    "for i in range(len(X)):\n",
    "    plt.plot([X[i], X[i]], [y[i], y_pred[i]], color='red')\n",
    "\n",
    "plt.xlabel(\"Years of Experience\")\n",
    "plt.ylabel(\"Salary\")\n",
    "plt.title(\"Simple Linear Regression\")\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "fc7fb42e",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 600x400 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.figure(figsize=(6,4))\n",
    "\n",
    "plt.plot(range(iterations), cost_history, color='blue')\n",
    "\n",
    "plt.xlabel(\"Number of Iterations\")\n",
    "plt.ylabel(\"Cost\")\n",
    "plt.title(\"Cost Function using Gradient Descent\")\n",
    "\n",
    "plt.show()"
   ]
  },
